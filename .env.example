# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exame_news

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-jwt-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password


# ----- REDIS -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT -----
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- API SERVER -----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ----- NEXT.JS PUBLIC -----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- OPENAI -----
OPENAI_API_KEY=sk-...

# ----- CLOUDINARY -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- EMAIL (SMTP) -----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EXAME News <noreply@exame.news>"

# ----- RATE LIMITING -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- BCRYPT -----
BCRYPT_SALT_ROUNDS=12
